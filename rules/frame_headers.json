[
  {
    "id": 1,
    "priority": 1,
    "action": {
      "type": "modifyHeaders",
      "responseHeaders": [
        {
          "header": "x-frame-options",
          "operation": "remove"
        },
        {
          "header": "frame-options",
          "operation": "remove"
        },
        {
          "header": "content-security-policy",
          "operation": "remove"
        },
        {
          "header": "content-security-policy-report-only",
          "operation": "remove"
        }
      ]
    },
    "condition": {
      "regexFilter": "^https?://",
      "resourceTypes": [
        "sub_frame"
      ]
    }
  },
  {
    "id": 2,
    "priority": 2,
    "action": {
      "type": "modifyHeaders",
      "requestHeaders": [
        {
          "header": "referer",
          "operation": "set",
          "value": "https://chrome-stream-layout.local/"
        }
      ]
    },
    "condition": {
      "regexFilter": "^https://(www\\.)?youtube(-nocookie)?\\.com/embed/",
      "resourceTypes": [
        "sub_frame"
      ]
    }
  }
]
